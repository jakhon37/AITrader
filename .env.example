# Copy to .env and fill in. Never commit .env or real secrets.
# ENV=dev
# CONFIG_DIR=config

# Broker (required for live; not needed for backtest/paper with mock)
# BROKER_API_URL=https://api-fxpractice.oanda.com
# BROKER_API_KEY=your-api-key
# BROKER_ACCOUNT_ID=your-account-id

# Optional: experiment tracking
# WANDB_PROJECT=trading-platform
# WANDB_MODE=offline
