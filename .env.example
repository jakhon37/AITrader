# AITrader — Environment Variables
# Copy this file to .env and fill in the values you need.
# NEVER commit .env (it is gitignored). No secrets belong in config/*.yaml.

# ------------------------------------------------------------------
# Core (usually set in shell or docker, but can be in .env)
# ------------------------------------------------------------------
# ENV=dev
# CONFIG_DIR=config

# ------------------------------------------------------------------
# D02 — Data Ingestion
# ------------------------------------------------------------------
# News (recommended for real-time fundamental signals)
# Put ONLY the key on its own line. No inline comments.
NEWSAPI_KEY=your_newsapi_key_here

# Finnhub — FX-focused market news (recommended for Live Feed accuracy)
# Free tier: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# FRED macro data (optional but used for regime features)
# Put ONLY the key on its own line.
FRED_API_KEY=your_fred_api_key

# ------------------------------------------------------------------
# D03 — Fundamental (LLM + Sentiment)
# ------------------------------------------------------------------
# OpenRouter (used for narrative synthesis + optional structured sentiment)
# Strongly recommended. Free tier works well with mistral models.
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_DAILY_BUDGET=2.0         # USD — safety cap, defaults to 1.0

# ------------------------------------------------------------------
# D07 — Notifier (Telegram)
# ------------------------------------------------------------------
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Comma-separated list supported for multiple destinations (group + personal etc.)
TELEGRAM_CHAT_ID=-1001234567890,649498120
ALLOWED_TELEGRAM_USER_IDS=649498120   # Comma-separated user IDs allowed to send commands

# ------------------------------------------------------------------
# D06 — Brokers (Live / Paper trading)
# ------------------------------------------------------------------
# Current primary: OANDA (practice account)
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=your-oanda-account-id

# NOTE: LIVE_TRADING_CONFIRMED must NEVER be in .env
# It is a deliberate safety gate. Set it only in your shell for each session:
#   export LIVE_TRADING_CONFIRMED=YES
# Only works when ENV=prod + execution_mode: live in prod.yaml

# ------------------------------------------------------------------
# FUTURE: MT5 Demo Account (MetaTrader 5)
# When you implement src/execution/brokers/mt5.py
# ------------------------------------------------------------------
# MT5_LOGIN=12345678
# MT5_PASSWORD=YourMt5Password123
# MT5_SERVER=MetaQuotes-Demo         # or your broker's demo server
# MT5_PATH=/path/to/terminal64.exe   # Optional: path to MT5 terminal if not in PATH

# ------------------------------------------------------------------
# FUTURE: Interactive Brokers (IBKR) — preferred for many regions
# When you implement src/execution/brokers/ibkr.py
# ------------------------------------------------------------------
# Common patterns (depends on ib_insync or official ibapi):
# IBKR_USERNAME=your_ibkr_user
# IBKR_PASSWORD=your_ibkr_password   # Or use API key if Web API
# IBKR_ACCOUNT=DU123456              # Paper or live account
# IB_HOST=127.0.0.1
# IB_PORT=7497                       # 7497=paper TWS, 4001=paper Gateway, 7496/4002=live
# IB_CLIENT_ID=1

# ------------------------------------------------------------------
# Optional / Dev tools
# ------------------------------------------------------------------
# WANDB_PROJECT=aitrader
# WANDB_MODE=offline
