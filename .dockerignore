# .dockerignore
# Ignore everything except pyproject.toml to keep image small
# Project files are mounted at runtime by docker_dev_*.sh scripts

*
!pyproject.toml

# Explicitly ignore these
.git/
.gitignore
.dockerignore
Dockerfile*
docker-compose.yml
docker/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Logs (will be mounted as volume)
logs/
*.log

# Data and models (will be mounted as volumes)
data/
models/
reports/

# Process IDs
*.pid

# Temporary files
*.tmp
.DS_Store

# Documentation
docs/
*.md

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml

# CI/CD
.github/

# Cache
.ruff_cache/
.mypy_cache/

# Large data files (will be mounted as volume)
data/raw/*.csv

# Model files (will be mounted as volume)
models/registry/models/*.pt

# Reports
reports/
